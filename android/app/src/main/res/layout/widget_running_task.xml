<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_amber"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@color/widget_accent_amber" />

        <TextView
            android:id="@+id/widget_status_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:text="ACTIVE · STANDBY"
            android:textColor="@color/widget_accent_amber"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_status_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text=""
            android:textColor="@color/widget_text_muted"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_task_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="NO PLAN SET"
        android:textColor="@color/widget_text_white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_task_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:maxLines="1"
        android:text="QUEUE STANDBY"
        android:textColor="@color/widget_text_mid"
        android:textSize="9sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:text="TODAY"
            android:textColor="@color/widget_text_muted"
            android:textSize="9sp" />

        <Chronometer
            android:id="@+id/widget_task_chronometer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:fontFamily="monospace"
            android:text=""
            android:textColor="@color/widget_accent_amber"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_task_today"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:fontFamily="monospace"
            android:text="00:00"
            android:textColor="@color/widget_accent_amber"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_btn_engage"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_primary_amber"
            android:gravity="center"
            android:text="ENGAGE"
            android:textColor="@color/widget_bg_deep"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/widget_btn_finish"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_btn_outline_amber"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="FINISH"
            android:textColor="@color/widget_accent_amber"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />
    </LinearLayout>
</LinearLayout>
