<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_journal_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_cyan"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@color/widget_accent_cyan" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.16"
            android:text="// REFLECTION LOG"
            android:textColor="@color/widget_accent_cyan"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_journal_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="0 ENTRIES"
            android:textColor="@color/widget_text_muted"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_journal_trigger"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="No logs yet. Tap + to log your first reflection."
        android:textColor="@color/widget_text_white"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_journal_emotion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:maxLines="1"
        android:text=""
        android:textColor="@color/widget_accent_cyan"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_journal_ts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:fontFamily="monospace"
        android:text=""
        android:textColor="@color/widget_text_muted"
        android:textSize="9sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_journal_btn_new"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_outline_cyan"
            android:gravity="center"
            android:text="+ NEW LOG"
            android:textColor="@color/widget_accent_cyan"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/widget_journal_btn_open"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_btn_outline_amber"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="ARCHIVE"
            android:textColor="@color/widget_accent_amber"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />
    </LinearLayout>
</LinearLayout>
